{
  "name": "lawflow-agent",
  "version": "1.4.5",
  "description": "LawFlow 로컬 에이전트 - 전자소송 인증서 연동 및 서류 제출",
  "author": "LawFlow",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.lawflow.agent",
    "productName": "LawFlow Agent",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": null,
      "uninstallerIcon": null,
      "artifactName": "LawFlow-Agent-Setup.exe",
      "shortcutName": "LawFlow Agent",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "forceCodeSigning": false,
    "publish": {
      "provider": "github",
      "owner": "re-rank",
      "repo": "lawflow-local-agent"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "src/**/*",
      "node_modules/ws/**/*",
      "node_modules/cloakbrowser/**/*",
      "node_modules/puppeteer-core/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/node-forge/**/*"
    ]
  },
  "dependencies": {
    "cloakbrowser": "^0.3.27",
    "electron-updater": "^6.8.3",
    "node-forge": "^1.4.0",
    "puppeteer-core": "^23.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  }
}
