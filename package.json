{
  "name": "lawflow-local-agent",
  "version": "0.1.0",
  "description": "LawFlow 로컬 에이전트 - 공동인증서 브릿지 및 전자소송 연동",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "package:win": "pkg dist/index.js -t node20-win-x64 -o lawflow-agent.exe",
    "package:mac": "pkg dist/index.js -t node20-macos-x64 -o lawflow-agent"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/ws": "^8.5.10",
    "@types/node-forge": "^1.3.11",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "pkg": "^5.8.1"
  }
}
